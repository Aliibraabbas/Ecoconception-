# Connexion Supabase PostgreSQL
# Supabase -> Project Settings -> Database -> Connection string (URI)
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# Port du serveur Express (optionnel, defaut 3001)
PORT=3001

# URL du projet Supabase (pour vérifier les JWT via JWKS - clés asymétriques, projets récents)
# Supabase -> Project Settings -> API -> Project URL
SUPABASE_URL=

# Clé publique (anon/publishable) - PAS un secret, safe à committer dans un client,
# mais on la lit depuis .env par convention. Utilisée uniquement par le script de seed
# (server/src/db/seed.js) pour créer/retrouver l'utilisateur de démo via l'API Auth publique.
# Supabase -> Project Settings -> API -> Project API keys -> anon / publishable
SUPABASE_ANON_KEY=

# Secret de vérification des JWT Supabase Auth (legacy, projets avec clé JWT partagée HS256)
# Supabase -> Project Settings -> API -> JWT Settings -> JWT Secret
SUPABASE_JWT_SECRET=

# Origine autorisée pour le CORS (URL du frontend)
CORS_ORIGIN=http://localhost:5173
