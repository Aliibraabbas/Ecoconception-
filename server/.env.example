# Connexion Supabase PostgreSQL
# Supabase -> Project Settings -> Database -> Connection string (URI)
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# Port du serveur Express (optionnel, defaut 3001)
PORT=3001

# URL du projet Supabase (requis : utilisé par le middleware d'auth pour valider
# les tokens via supabase.auth.getUser, et par le script de seed)
# Supabase -> Project Settings -> API -> Project URL
SUPABASE_URL=

# Clé publique (anon/publishable) - PAS un secret, safe à committer dans un client,
# mais on la lit depuis .env par convention. Requise par le middleware d'auth
# (supabase.auth.getUser) et par le script de seed (server/src/db/seed.js).
# Supabase -> Project Settings -> API -> Project API keys -> anon / publishable
SUPABASE_ANON_KEY=

# Origine autorisée pour le CORS (URL du frontend)
CORS_ORIGIN=http://localhost:5173
